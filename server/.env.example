# 环境变量配置模板
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# AI 提供商（可选，默认自动检测）
AI_PROVIDER=auto

# Google Gemini（免费 1500次/天）
# 申请: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# DeepSeek（注册送 500万 token）
# 申请: https://platform.deepseek.com
# DEEPSEEK_API_KEY=

# SiliconFlow（注册送 2000万 token）
# 申请: https://cloud.siliconflow.cn
# SILICONFLOW_API_KEY=

# OpenAI（付费）
# OPENAI_API_KEY=

# JWT 密钥
JWT_SECRET=ai_homework_grader_secret_key_2024

# 服务端口
PORT=3001
